{
  "name": "beam-overlay",
  "version": "0.1.0",
  "description": "Three.js overlay for directional range-sensor detection volumes (ultrasonic, radar, IR, ToF) with correct multi-beam surface culling via GLSL",
  "type": "module",
  "license": "MIT",
  "author": "zicorn",
  "homepage": "https://github.com/chenzikun/beam-overlay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenzikun/beam-overlay.git"
  },
  "bugs": {
    "url": "https://github.com/chenzikun/beam-overlay/issues"
  },
  "keywords": [
    "three",
    "threejs",
    "webgl",
    "glsl",
    "shader",
    "visualization",
    "sensor",
    "range-sensor",
    "ultrasonic",
    "radar",
    "lidar",
    "proximity",
    "beam",
    "overlay",
    "robotics"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "three": "^0.185.0",
    "@types/three": "^0.185.0",
    "vite": "^5.2.0",
    "vite-plugin-glsl": "^1.3.0",
    "vite-plugin-dts": "^3.9.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
